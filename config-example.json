{
  "categories": {
    "Imágenes": {
      "category": "Imágenes",
      "enabled": true,
      "organize_by_date": true,
      "extensions": [
        ".jpg",
        ".jpeg",
        ".png",
        ".gif",
        ".bmp",
        ".tiff",
        ".tif",
        ".webp",
        ".heic",
        ".raw",
        ".cr2",
        ".nef",
        ".arw"
      ],
      "regex_patterns": [
        "^IMG_\\d{8}_\\d{6}.*",
        "^DSC\\d+.*",
        "^screenshot.*"
      ]
    },
    "Vídeos": {
